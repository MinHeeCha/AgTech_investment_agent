# Environment variables for AgTech Investment Evaluation System

# LLM Configuration
LLM_MODEL=claude-3-haiku
EMBEDDING_MODEL=BAAI/bge-m3
OPENAI_API_KEY=your_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# RAG Configuration
CHUNK_SIZE=1024
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
RELEVANCE_THRESHOLD=0.5

# Agent Configuration
MAX_PARALLEL_WORKERS=4
AGENT_TIMEOUT=300

# Evaluation Thresholds
STRONG_INVEST_THRESHOLD=0.75
INVEST_THRESHOLD=0.60
HOLD_THRESHOLD=0.40

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=investment_evaluation.log

# Data Configuration
DATA_DIR=data
OUTPUT_DIR=outputs

# Database Configuration (optional)
DATABASE_URL=sqlite:///./agtech_eval.db
